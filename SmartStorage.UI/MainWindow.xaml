<Window x:Class="SmartStorage.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart Storage Optimizer" Height="720" Width="1180" WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Smart Storage Optimizer" FontSize="24" FontWeight="SemiBold" />

        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,16,0,16">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBox Width="800" Text="{Binding RootPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                <Button Width="140" Content="🔍 Index PC Files" Command="{Binding IndexCommand}" />
                <Button Width="140" Content="📊 Analyze from Index" Command="{Binding ScanCommand}" Margin="8,0,0,0" />
            </StackPanel>
            <TextBlock FontWeight="Bold" Foreground="#0066CC" Text="{Binding CurrentPhase, StringFormat='Current Phase: {0}'}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
            <ProgressBar Width="940" Height="18" Minimum="0" Maximum="100" Value="{Binding ProgressValue}" />
            <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" Text="{Binding ProgressText}" />
        </StackPanel>

        <GroupBox Grid.Row="3" Header="Activity Log" Margin="0,0,0,12">
            <Border Padding="8">
                <ListBox ItemsSource="{Binding Logs}" BorderThickness="0" Background="Transparent">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </Border>
        </GroupBox>

        <DataGrid Grid.Row="4" ItemsSource="{Binding Results}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*" />
                <DataGridTextColumn Header="Type" Binding="{Binding Kind}" Width="120" />
                <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="90" />
                <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="300" />
                <DataGridTextColumn Header="Tags" Binding="{Binding Tags}" Width="250" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="5" Margin="0,12,0,0" Text="{Binding Status}" />
    </Grid>
</Window>
